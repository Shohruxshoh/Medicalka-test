# ── Application ────────────────────────────────
APP_NAME=Mini Social Network API
DEBUG=true

# ── PostgreSQL (async driver for the app) ──────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/social

# ── Redis (cache + Celery broker) ──────────────
REDIS_URL=redis://redis:6379/0

# ── JWT / security ─────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email verification ─────────────────────────
VERIFICATION_TOKEN_EXPIRE_HOURS=24
UNVERIFIED_USER_TTL_HOURS=48

# ── Views (Redis buffering) ────────────────────
VIEW_DEDUP_TTL_SECONDS=3600
VIEW_FLUSH_INTERVAL_SECONDS=10

# ── Post TTL (Bonus) ───────────────────────────
POST_TTL_DAYS=30

# ── Login rate limiting (Bonus) ────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=300
